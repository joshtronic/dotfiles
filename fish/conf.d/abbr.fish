# Prompt when doing something destructive
abbr cp 'cp -i'
abbr mv 'mv -i'
abbr rm 'rm -i'

# Make disk utilities human-readable
abbr df 'df -h'
abbr du 'du -h'

# Docker
abbr dcu 'docker-compose up'
abbr dcd 'docker-compose down'

# Git
abbr gaa 'git add --all'
abbr gca 'git commit -a'
abbr gcam 'git commit -a --amend'
abbr gcb 'git checkout -b'
abbr gco 'git checkout'
abbr gd 'git diff'
abbr gl 'git pull'
abbr gp 'git push'
abbr gst 'git status'
