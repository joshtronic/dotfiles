#!/usr/bin/env zsh

# Setup some basic environment variables
export CLICOLOR=1
export EDITOR=vim
export KEYTIMEOUT=1
export QUOTING_STYLE=literal
export DOTFILES=$HOME/.dotfiles

source $DOTFILES/zsh/aliases.zsh
source $DOTFILES/zsh/prompt.zsh
source $DOTFILES/zsh/rose-pine-moon.zsh

# Load up and configure fnm, fzf, and zsh plugins
if [[ $(uname) == Darwin ]]; then
  # From `eval "$(/opt/homebrew/bin/brew shellenv)"`:
  export HOMEBREW_PREFIX="/opt/homebrew";
  export HOMEBREW_CELLAR="/opt/homebrew/Cellar";
  export HOMEBREW_REPOSITORY="/opt/homebrew";
  fpath[1,0]="/opt/homebrew/share/zsh/site-functions";
  eval "$(/usr/bin/env PATH_HELPER_ROOT="/opt/homebrew" /usr/libexec/path_helper -s)"
  export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/gcr/ssh"

  [ -z "${MANPATH-}" ] || export MANPATH=":${MANPATH#:}";
  export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}";

  # Speed up `brew install`
  export HOMEBREW_NO_AUTO_UPDATE=1
  export HOMEBREW_NO_INSTALL_CLEANUP=1

  FNM_PATH="$HOMEBREW_PREFIX/opt/fnm/bin"
  PATH="$HOMEBREW_PREFIX/sbin:$PATH"
  PATH="$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin:$PATH"

  [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
else
  source /usr/share/doc/fzf/examples/completion.zsh
  source /usr/share/doc/fzf/examples/key-bindings.zsh

  FNM_PATH="/home/josh/.local/share/fnm"
fi

export PATH="$HOME/.local/bin:$FNM_PATH:$PATH"

ZSH_PLUGINS="$HOME/.zsh/plugins"
source "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZSH_PLUGINS/zsh-history-substring-search/zsh-history-substring-search.zsh"
source "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

HISTFILE=$HOME/.zsh_history
HISTSIZE=1000000
SAVEHIST=1000000

zstyle ':completion:*' menu select
# zstyle ':completion:*' completer _expand_alias _complete
zstyle ':completion:*' completer _complete
zstyle ':completion:*' matcher-list '' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]}' '+l:|=* r:|=*'

autoload -Uz compinit && compinit -C
zmodload -i zsh/complist

unsetopt menu_complete
unsetopt flowcontrol

setopt prompt_subst
setopt always_to_end
setopt append_history
setopt auto_menu
setopt complete_in_word
setopt extended_history
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_verify
setopt inc_append_history
setopt interactivecomments
setopt share_history

bindkey -v
bindkey '^a' beginning-of-line
bindkey '^e' end-of-line
# bindkey "^Xa" _expand_alias
# zsh-autosuggestions
bindkey '^f' autosuggest-accept
# zsh-history-substring-search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
HISTORY_SUBSTRING_SEARCH_ENSURE_UNIQUE=1

autoload -Uz edit-command-line
zle -N edit-command-line
bindkey "^x^e" edit-command-line

eval "$(fnm env --shell zsh --use-on-cd --version-file-strategy recursive)"
